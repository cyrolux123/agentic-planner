# Copy this file to .env and adjust OLLAMA_HOST for your environment.
#
# Windows / macOS Docker Desktop:
OLLAMA_HOST=http://host.docker.internal:11434
#
# Linux Docker (bridge network default):
# OLLAMA_HOST=http://172.17.0.1:11434
#
# Running without Docker (local):
# OLLAMA_HOST=http://localhost:11434

# Primary model. Falls back to mistral automatically if not found.
OLLAMA_MODEL=llama3
